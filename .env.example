# Copy this file to .env and fill in values from your Firebase project settings
# (Project settings > General > Your apps > Web app config).
# Vars must be prefixed with EXPO_PUBLIC_ to be readable in client code.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OAuth 2.0 Client IDs from Google Cloud Console (APIs & Services > Credentials).
# Used by expo-auth-session for native Google Sign-In on Android.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Set to "true" to point the app at a local `firebase emulators:start` instance
# instead of your real Firebase project. Handy for development without touching
# production data.
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false
