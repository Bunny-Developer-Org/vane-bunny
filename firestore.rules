rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each user owns their own subtree: users/{uid} (profile fields) and
    // users/{uid}/moodEntries/{entryId}. No one else may read or write it.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /moodEntries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
